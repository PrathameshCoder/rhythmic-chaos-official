# =============================================================================
# Rhythmic Chaos — Public website environment variables
# Copy to .env.local and fill in. Never commit .env.local.
# =============================================================================

# ── Site ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://rhythmicchaos.live

# ── Supabase (release data) ──────────────────────────────────────────────────
# The public site READS releases with the anon key (RLS-protected).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Optional on the public site (not required for reads). Server-only if used.
# Do NOT expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Shared secret so the dashboard can trigger ISR revalidation here.
# MUST match SUPABASE_REVALIDATION_SECRET in the admin-dashboard project.
# Generate one:  openssl rand -hex 32
SUPABASE_REVALIDATION_SECRET=your_shared_revalidation_secret_here

# ── Resend (email: contact + newsletter) ─────────────────────────────────────
RESEND_API_KEY=your_resend_api_key_here
CONTACT_EMAIL=your_contact_email_here
NEWSLETTER_EMAIL=your_newsletter_email_here

# Optional: verified sender (defaults to onboarding@resend.dev for testing)
# RESEND_FROM_EMAIL=Rhythmic Chaos <hello@yourdomain.com>
